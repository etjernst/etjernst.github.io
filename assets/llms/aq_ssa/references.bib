  title = {Monthly global estimates of fine particulate matter and their uncertainty},
  author = {Van Donkelaar, Aaron and Hammer, Melanie S. and Bindle, Liam and Brauer, Michael and Brook, Jeffery R. and Garay, Michael J. and Hsu, N. Christina and Kalashnikova, Olga V. and Kahn, Ralph A. and Lee, Colin and Levy, Robert C. and Lyapustin, Alexei and Sayer, Andrew M. and Martin, Randall V.},
